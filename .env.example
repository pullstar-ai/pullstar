# PullStar 1-on-1 — Secrets
# Copy this file to .env and fill in your values.
# .env must contain secrets ONLY — never commit it.
#
# Provider/model selection does NOT belong here.
# Use model_provider.json for provider, model, temperature, and max_tokens.
# Copy model_provider.json.example to model_provider.json to get started.

# ---------------------------------------------------------------------------
# GitHub (required)
# ---------------------------------------------------------------------------

# Classic personal access token — required scope: repo
# Create one at: https://github.com/settings/tokens
# Fine-grained PATs do not support cross-user search — use a classic PAT.
GITHUB_TOKEN=your_github_token_here

# GitHub organization name (optional)
# If set, ingestion is scoped to this org. Omit to search all accessible repos.
GITHUB_ORG=

# ---------------------------------------------------------------------------
# AI Provider keys — set the one matching your model_provider.json provider
# ---------------------------------------------------------------------------

# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# OPENROUTER_API_KEY=your_key_here     # https://openrouter.ai/keys
# TOGETHER_API_KEY=your_key_here       # https://api.together.xyz
# HUGGINGFACE_API_KEY=your_key_here    # https://huggingface.co/settings/tokens

# ---------------------------------------------------------------------------
# UI (optional)
# ---------------------------------------------------------------------------

# Pro waitlist link shown in the UI. Leave unset to hide.
# VITE_PRO_WAITLIST_URL=https://example.com/waitlist
